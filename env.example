# ==========================================
# STATIFY 2.0 - ENV CONFIGURATION TEMPLATE
# ==========================================

# 1. Google Gemini API Configuration
# Required for live AI Sports Strategist evaluations and dynamic parameter generation.
# In Google AI Studio, this is automatically injected via the Secrets panel.
GEMINI_API_KEY="your_gemini_api_key_here"

# 2. Application and Host URLs
# AI Studio automatically injects APP_URL at runtime with the Cloud Run service URL.
APP_URL="https://your-app-url-here.run.app"

# Optional backend endpoint if hosting FastAPI on a distinct host/port
# Default fallback is localhost:8000 when running backend python scripts
BACKEND_URL="http://localhost:8000"

# 3. Server Node Configuration
# Configures node and server mode
NODE_ENV="development"
PORT=3000
